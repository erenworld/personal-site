---
import Layout from "../components/Layout.astro";
import Prose from "../components/Prose.astro";
import SubscribeForm from "../components/NewsletterForm.astro";
import GitHubContributions from "../components/GitHubContributions.astro";
import { getCollection } from "astro:content";
import { getBlogPosts } from "../data/utils";

const posts = await getBlogPosts();
const newestPosts = posts.slice(0, 5);

const booknotes = await getCollection("booknotes");
booknotes.sort(
  (a, b) => b.data.finishedAt.getTime() - a.data.finishedAt.getTime(),
);

const linksClass = "w-fit font-bold";
---

<Layout image={new URL("og/home.png", Astro.url)}>
  <div class="flex flex-row justify-between items-center mb-2">
    <h1 class="font-bold text-2xl">Eren Türkoglu</h1>
  </div>
  <Prose>
    <p>
      I'm 21 years old, originally from Türkiye, born in France, and I've spent
      most of my life between Nancy and Afyon.
    </p>
    <p>
      Previously, I was the first Software Engineer at <a
        href="https://kolizeo.fr"
        target="_blank"
      >
        Kolizeo</a
      >
      where I built the initial web version as an intern. It was used by major sports
      clubs and reached audiences of up to 3,000 spectators. <span
        class="text-google-yellow"
      >
      </span>
    </p>

    <p>
      In my free time, I build open-source projects such as
      <a href="https://github.com/erenworld/chalk" target="_blank">Chalk</a>,
      <a href="https://github.com/erenworld/karp" target="_blank">Karp</a> or
      <a href="https://github.com/erenworld/toy-database" target="_blank"
        >Sqlite</a
      >. I also have a <a href="/blog">blog</a> where I write about stuff I find interesting
      enough to share.
    </p>
    <p>
      If anything here piques your interest, don't hesitate to{" "}
      <a href="mailto:erenxturkoglu@gmail.com" target="_blank">reach out</a>. I
      love meeting new people!
    </p>

    <!-- GITHUB CONTRIBUTIONS COMPONENT -->
    <GitHubContributions />

    <div>
      <h3>Newest Posts</h3>
      <ul class="flex flex-col gap-4 not-prose">
        {
          newestPosts.map((post) => (
            <li>
              <span class="flex gap-1 items-center">
                <span class="flex-1">
                  <a href={`/${post.id}`}>
                    <span class="font-bold font-serif text-lg">
                      {post.data.title}
                    </span>
                    {post.data.author && <span> ({post.data.author})</span>}
                  </a>
                </span>
                <span>
                  {post.data.date.toLocaleDateString("en-GB", {
                    day: "numeric",
                    month: "short",
                    year: "2-digit",
                  })}
                </span>
              </span>
            </li>
          ))
        }
      </ul>
      <h3 class="font-bold">Newsletter</h3>
      <SubscribeForm />
      <h3>Links</h3>
      <div class="not-prose grid grid-cols-3 sm:grid-cols-4">
        <a class={linksClass} href="https://x.com/erentrkg" target="_blank"
          >Twitter/X</a
        >
        <a
          class={linksClass}
          href="https://github.com/erenworld"
          target="_blank">GitHub</a
        >
        <a
          class={linksClass}
          href="https://www.youtube.com/@eren"
          target="_blank">YouTube</a
        >
        <a
          class={linksClass}
          href="https://www.instagram.com/eren.turkogllu"
          target="_blank"
        >
          Instagram
        </a>
        <a
          class={linksClass}
          href="https://www.linkedin.com/in/erenturkoglu"
          target="_blank"
        >
          LinkedIn
        </a>
        <a
          class={linksClass}
          href="https://github.com/erenworld/personal-site"
          target="_blank"
        >
          Source Code
        </a>
        <a
          class={linksClass}
          href="https://letterboxd.com/erenworld/"
          target="_blank"
        >
          Letterboxd
        </a>
        <a class={linksClass} href="https://nav.al/happiness" target="_blank">
          Life lesson
        </a>
      </div>
    </div>

    <div>
      <h2>Bucketlist</h2>

      <!-- Items cochés (barrés) -->
      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
          <path
            d="M6 10l3 3 5-5"
            fill="none"
            stroke="#000000"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <label class="font-medium text-heading line-through"
          >Visit Luxembourg</label
        >
      </div>

      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
          <path
            d="M6 10l3 3 5-5"
            fill="none"
            stroke="#000000"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <label class="font-medium text-heading line-through"
          >Read 25 books</label
        >
      </div>

      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
          <path
            d="M6 10l3 3 5-5"
            fill="none"
            stroke="#000000"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <label class="font-medium text-heading line-through"
          >Work in a Startup</label
        >
      </div>

      <!-- Items non cochés (sans barré) -->
      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
        </svg>
        <label class="font-medium text-heading">Live in Istanbul</label>
      </div>

      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
        </svg>
        <label class="font-medium text-heading"
          >Go to New Zealand & Antarctica</label
        >
      </div>

      <div class="flex items-center mb-2">
        <svg width="20" height="20" viewBox="0 0 20 20" class="mr-2">
          <rect
            x="2"
            y="2"
            width="16"
            height="16"
            fill="none"
            stroke="#000000"
            stroke-width="2"></rect>
        </svg>
        <label class="font-medium text-heading">Found own startup</label>
      </div>
    </div>
    <div>
      <h2>Bookshelf</h2>
      <div class="not-prose flex flex-col gap-1">
        {
          booknotes.map((book) => (
            <a
              href={`/books/${book.id}`}
              class="group grid grid-cols-[minmax(0,1fr)_auto] items-start gap-x-4 gap-y-1 rounded-sm text-current no-underline hover:text-current hover:no-underline sm:grid-cols-[minmax(0,1fr)_auto_auto]"
            >
              <span class="text-lg text-blue-600 group-hover:underline">
                {book.data.title}
              </span>
              <span
                aria-label={`${book.data.rating} out of 5 stars`}
                class="flex gap-0.5 text-slate-800 sm:justify-self-end"
              >
                {Array.from({ length: 5 }, (_, index) => (
                  <span class={index < book.data.rating ? "text-slate-800" : "text-slate-300"}>
                    ★
                  </span>
                ))}
              </span>
              <span class="text-sm text-slate-500 sm:text-base">
                {book.data.finishedAt.toLocaleDateString("en-US", {
                  month: "short",
                  year: "numeric",
                })}
              </span>
            </a>
          ))
        }
      </div>
      <p>
        You can see the rest on my{" "}
        <a href="https://letterboxd.com/erenworld/likes/films/by/date/size/large/">
          Letterboxd
        </a>.
      </p>
    </div>
  </Prose>
</Layout>
